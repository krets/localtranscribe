{
  "name": "Local Voice Scribe",
  "short_name": "Scribe",
  "start_url": "/transcribe/",
  "display": "standalone",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "/transcribe/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [{ "name": "audio_file", "accept": ["audio/*"] }]
    }
  }
}

